<script>
const cur=document.getElementById('cur'),ring=document.getElementById('cur-ring');
let mx=0,my=0,rx=0,ry=0;
document.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY;cur.style.left=mx+'px';cur.style.top=my+'px'});
(function loop(){rx+=(mx-rx)*.1;ry+=(my-ry)*.1;ring.style.left=rx+'px';ring.style.top=ry+'px';requestAnimationFrame(loop)})();
document.querySelectorAll('a,button,.skill-chip,.a-val,.svc-card,.proj-card,.proj-featured,.cert-card,.testi-card,.soft-tag,.hstat,.edu-tag').forEach(el=>{
  el.addEventListener('mouseenter',()=>{cur.style.width='18px';cur.style.height='18px';ring.style.width='54px';ring.style.height='54px'});
  el.addEventListener('mouseleave',()=>{cur.style.width='9px';cur.style.height='9px';ring.style.width='34px';ring.style.height='34px'});
});
window.addEventListener('scroll',()=>document.getElementById('main-nav').classList.toggle('scrolled',window.scrollY>60));
document.querySelectorAll('a[href^="#"]').forEach(a=>{
  a.addEventListener('click',e=>{
    const t=document.querySelector(a.getAttribute('href'));
    if(t){e.preventDefault();t.scrollIntoView({behavior:'smooth'})}
  });
});
const obs=new IntersectionObserver(entries=>entries.forEach(e=>{if(e.isIntersecting)e.target.classList.add('in')}),{threshold:.08});
document.querySelectorAll('.reveal').forEach(el=>obs.observe(el));

const STORAGE_KEY='mf_portfolio_reviews_v1';
function loadReviews(){
  let rv=[];try{rv=JSON.parse(localStorage.getItem(STORAGE_KEY)||'[]')}catch(e){}
  const wrap=document.getElementById('dyn-testis');
  if(!rv.length){wrap.innerHTML='';return}
  const grid=document.createElement('div');grid.className='testi-grid';
  rv.forEach(r=>{
    const ini=(r.name||'?').trim().split(' ').map(w=>w[0]||'').join('').slice(0,2).toUpperCase();
    const c=document.createElement('div');c.className='testi-card';
    c.innerHTML=`<div class="testi-q">"</div><div class="testi-text">${escHtml(r.text)}</div><div class="testi-stars">${r.rating||'★★★★★'}</div><div class="testi-author"><div class="testi-av">${ini}</div><div><div class="testi-name">${escHtml(r.name)}</div><div class="testi-role">${escHtml(r.role||'Client / Collaborator')}</div></div></div><div style="font-family:'JetBrains Mono',monospace;font-size:.55rem;color:var(--dim2);margin-top:1rem">${r.date||''}</div>`;
    grid.appendChild(c);
  });
  wrap.innerHTML='';wrap.appendChild(grid);
}
function escHtml(s){return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;')}
loadReviews();

function submitReview(){
  const name=document.getElementById('rv-name').value.trim();
  const role=document.getElementById('rv-role').value.trim();
  const rating=document.getElementById('rv-rating').value;
  const text=document.getElementById('rv-text').value.trim();
  const msg=document.getElementById('rv-msg');
  if(!name||!text){msg.className='f-notice err';msg.textContent='Please fill in your name and review.';return}
  if(text.length<10){msg.className='f-notice err';msg.textContent='Please write a more detailed review (min 10 characters).';return}
  let rv=[];try{rv=JSON.parse(localStorage.getItem(STORAGE_KEY)||'[]')}catch(e){}
  rv.push({name,role,rating,text,date:new Date().toLocaleDateString('en-GB',{day:'numeric',month:'short',year:'numeric'})});
  localStorage.setItem(STORAGE_KEY,JSON.stringify(rv));
  loadReviews();
  msg.className='f-notice ok';msg.textContent='✓ Thank you '+name+'! Your review is now live above.';
  document.getElementById('rv-name').value='';
  document.getElementById('rv-role').value='';
  document.getElementById('rv-text').value='';
  const emailBody=`New Portfolio Review\n\nFrom: ${name}\nRole: ${role||'-'}\nRating: ${rating}\nDate: ${new Date().toLocaleDateString()}\n\nReview:\n${text}`;
  setTimeout(()=>{window.location.href=`mailto:moustafa2005omar@gmail.com?subject=${encodeURIComponent('⭐ New Review from '+name+' — Portfolio')}&body=${encodeURIComponent(emailBody)}`},1200);
}

function sendContact(){
  const name=document.getElementById('ct-name').value.trim();
  const email=document.getElementById('ct-email').value.trim();
  const subj=document.getElementById('ct-subj').value.trim();
  const body=document.getElementById('ct-body').value.trim();
  const msg=document.getElementById('ct-msg');
  if(!name||!email||!body){msg.className='f-notice err';msg.textContent='Please fill in all required fields.';return}
  if(!email.includes('@')){msg.className='f-notice err';msg.textContent='Please enter a valid email address.';return}
  window.location.href=`mailto:moustafa2005omar@gmail.com?subject=${encodeURIComponent(subj||'Portfolio Contact from '+name)}&body=${encodeURIComponent('From: '+name+'\nEmail: '+email+'\n\n'+body)}`;
  msg.className='f-notice ok';msg.textContent='✓ Your email client should open. Thank you, '+name+'!';
  document.getElementById('ct-name').value='';document.getElementById('ct-email').value='';
  document.getElementById('ct-subj').value='';document.getElementById('ct-body').value='';
}
